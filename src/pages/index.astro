---
import Layout from '../layouts/Layout.astro';
import { getAllProblems } from '../lib/data.ts';

const problems = await getAllProblems();
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Layout title="Problem Solving Gym">
  <main class="wrap">
    <header class="hero">
      <h1 class="marquee">PROBLEM SOLVING GYM</h1>
      <p class="tagline">// SHIP CODE. BEAT THE CLOCK. CLAIM YOUR RANK.</p>
    </header>

    <section class="list">
      {problems.map((p) => (
        <a class="card" href={`/problems/${p.slug}`}>
          <span class="card-title">{p.title}</span>
          <span class="card-date">{fmtDate(p.published_at)}</span>
          <span class="card-arrow">→</span>
        </a>
      ))}
      {problems.length === 0 && (
        <p class="empty">No problems yet. Add one in <code>problems/</code>.</p>
      )}
    </section>
  </main>

  <style>
    .wrap { max-width: 960px; margin: 0 auto; padding: 80px 24px 120px; }
    .hero { text-align: center; margin-bottom: 72px; }
    .marquee {
      font-family: var(--font-display);
      font-size: clamp(20px, 4vw, 40px);
      line-height: 1.4;
      letter-spacing: 0.04em;
      color: var(--accent);
      margin: 0 0 24px;
      text-shadow: 0 0 12px rgba(57, 255, 20, 0.35);
    }
    .tagline {
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--fg-dim);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin: 0;
    }
    .list { display: flex; flex-direction: column; gap: 16px; }
    .card {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: center;
      gap: 24px;
      padding: 24px 28px;
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-left: 4px solid var(--border);
      color: var(--fg);
      transition: border-color 120ms ease, transform 120ms ease, background 120ms ease;
    }
    .card:hover {
      border-left-color: var(--accent);
      background: var(--bg-elev-2);
      transform: translateX(2px);
      text-decoration: none;
    }
    .card-title { font-size: 18px; font-weight: 700; }
    .card-date {
      font-size: 13px;
      color: var(--fg-dim);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .card-arrow { color: var(--accent); font-size: 20px; }
    .empty { color: var(--fg-dim); text-align: center; padding: 48px 0; }
  </style>
</Layout>
